#!/bin/sh
# scripts/test-package -- run autopkgtest + piuparts against the
# Avalan binary `.deb` produced by scripts/build-binary.
#
# Both tools are Noble-only (they drive apt + chroot machinery), so
# this script bails out with a clear message on a non-Debian dev
# host. From a Noble VM or container with the Avalan PPA enabled, a
# bare `scripts/test-package` is what gates Phase 5.

set -eu
set -x

script_dir=$(cd "$(dirname "$0")" && pwd)
repo_root=$(cd "$script_dir/.." && pwd)
cd "$repo_root"

require_tool() {
    if ! command -v "$1" >/dev/null 2>&1; then
        set +x
        echo "FATAL: '$1' not on PATH." >&2
        echo "       autopkgtest + piuparts are Noble-only -- run" >&2
        echo "       scripts/test-package from a Noble VM/container." >&2
        exit 1
    fi
}
require_tool autopkgtest
require_tool piuparts

# Locate the most recent Avalan binary build. scripts/build-binary
# drops the .changes alongside the .deb in build/.
changes=$(ls -1t build/avalan_*_*.changes 2>/dev/null | grep -v _source.changes | head -n1 || true)
deb=$(ls -1t build/avalan_*.deb 2>/dev/null | head -n1 || true)
if [ -z "$changes" ] || [ -z "$deb" ]; then
    set +x
    echo "FATAL: no Avalan binary .changes / .deb found under build/." >&2
    echo "       Run scripts/build-binary first." >&2
    exit 1
fi

# 1. autopkgtest against the installed binary. `-- null` runs in the
# host environment without spinning up a Noble chroot; the user can
# point at a real `lxc` / `qemu` runner by overriding $AUTOPKGTEST_BACKEND.
backend=${AUTOPKGTEST_BACKEND:-null}
autopkgtest "$changes" -- "$backend"

# 2. piuparts -- full install / remove / purge / reinstall cycle.
# `--no-install-recommends` matches the install profile we document
# in README.md so the test exercises the same dependency closure end
# users will see. Drops nothing under /usr/lib/python3/dist-packages
# after purge (piuparts -- not us -- enforces that).
sudo piuparts \
    --apt \
    --no-install-recommends \
    --no-eatmydata \
    "$deb"
