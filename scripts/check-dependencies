#!/bin/sh
# scripts/check-dependencies — audit debian/dependency-map.toml against
# the upstream sdist, the Homebrew formula, and apt-cache madison.
# Thin POSIX shim around scripts/check_dependencies.py so the script
# fits the rest of scripts/ stylistically while the actual logic stays
# importable for unit tests.

set -eu

script_dir=$(cd "$(dirname "$0")" && pwd)

# When invoked from a checkout, enforce the per-dep packaging layout
# (packages/<source>/debian/) alongside the rest of the audit. Tests
# call check_dependencies.py directly and opt in explicitly per case,
# so the flag stays out of the Python default to avoid surprising
# fixture-driven runs.
have_flag=0
for arg in "$@"; do
    case "$arg" in
        --packages-dir|--packages-dir=*)
            have_flag=1
            break
            ;;
    esac
done

if [ "$have_flag" -eq 0 ]; then
    set -- --packages-dir packages "$@"
fi

exec python3 "$script_dir/check_dependencies.py" "$@"
