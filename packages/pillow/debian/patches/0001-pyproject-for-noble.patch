Description: Soften pyproject metadata for Noble's setuptools
 Noble ships python3-setuptools at a version (68.x) that predates
 the PEP 639 license-files list form Pillow 11.3.0 emits, and the
 upstream `[build-system].requires = "setuptools>=77"` pin
 explicitly excludes anything Noble has. Two changes: drop the
 setuptools lower bound back to >= 62 (which Noble satisfies and
 which Pillow's _custom_build/backend.py is happy with), and
 rewrite `license = "MIT-CMU"` + `license-files = [...]` to the
 legacy `license = { text = "MIT-CMU" }` table form. Wheel license
 metadata is equivalent; no runtime impact.
Author: Avalan Packaging Team <avalan@avalan.ai>
Forwarded: not-needed
Last-Update: 2026-05-18

--- a/pyproject.toml
+++ b/pyproject.toml
@@ -1,7 +1,7 @@
 [build-system]
 build-backend = "backend"
 requires = [
-  "setuptools>=77",
+  "setuptools >= 62",
 ]
 backend-path = [
   "_custom_build",
@@ -14,8 +14,7 @@
 keywords = [
   "Imaging",
 ]
-license = "MIT-CMU"
-license-files = [ "LICENSE" ]
+license = { text = "MIT-CMU" }
 authors = [
   { name = "Jeffrey A. Clark", email = "aclark@aclark.net" },
 ]
