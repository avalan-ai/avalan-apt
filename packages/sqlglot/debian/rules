#!/usr/bin/make -f

export PYBUILD_NAME=sqlglot
export PYBUILD_SYSTEM=pyproject

# Block any accidental network use during build/test.
export PIP_NO_INDEX=1
export PIP_NO_BUILD_ISOLATION=1

# setuptools_scm reads the version from PKG-INFO when building from an
# sdist, but pin it explicitly so a stray .git tree on the build host
# (e.g. when iterating locally) cannot shadow the sdist's version.
export SETUPTOOLS_SCM_PRETEND_VERSION_FOR_SQLGLOT=27.29.0

%:
	dh $@ --buildsystem=pybuild

# Upstream's tests need duckdb, pandas, and a network-fetched suite of
# reference SQL files. Skip at build time; correctness comes from
# upstream CI and the Avalan smoke import.
override_dh_auto_test:
	@echo "Skipping upstream tests at build time; see debian/tests/."
