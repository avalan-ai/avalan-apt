Description: Soften pyproject for Noble's setuptools and archived aiohttp
 Four small, independent metadata tweaks bundled into one patch
 because they collapse to the same goal -- making aiobotocore build
 and install against Noble's archive:
 .
 * Relax the strict `setuptools >= 77.0.0` build-system pin to
   plain `setuptools`. Noble ships python3-setuptools 68; the
   actual build machinery aiobotocore uses (setuptools.build_meta
   + dynamic version/readme attrs) works on every release back to
   setuptools 64. Upstream lifted the floor solely so PEP 639 SPDX
   license validation would succeed.
 * Rewrite the PEP 639 SPDX string `license = "Apache-2.0"` back
   to the legacy `license = { file = "LICENSE" }` table form
   Noble's older setuptools accepts; otherwise wheel metadata
   validation rejects the pyproject as ambiguous against the
   auto-detected LICENSE file.
 * Drop the `Programming Language :: Python :: 3.14` trove
   classifier. Noble's setuptools classifier table predates
   Python 3.14 and refuses to emit the wheel until the unknown
   entry is removed. Purely informational; no runtime impact.
 * Soften the runtime `aiohttp >= 3.9.2, < 4.0.0` floor to
   `>= 3.9.1, < 4.0.0`. Noble ships python3-aiohttp 3.9.1-1ubuntu0.1
   (also rolled into noble-security/noble-updates); the gap between
   3.9.1 and 3.9.2 is a single CVE backport on the response-parsing
   path that aiobotocore does not exercise differently across the
   two releases. Lifting Noble's aiohttp to 3.9.2+ would require
   rebuilding it for the PPA for no observable benefit.
Author: Avalan Packaging Team <avalan@avalan.ai>
Forwarded: not-needed
Last-Update: 2026-05-20

--- a/pyproject.toml
+++ b/pyproject.toml
@@ -1,5 +1,5 @@
 [build-system]
-requires = ["setuptools>=77.0.0"]
+requires = ["setuptools"]
 build-backend = "setuptools.build_meta"

 [project]
@@ -9,7 +9,7 @@ requires-python = ">=3.9"
 authors = [
     { name = "Nikolay Novik", email = "nickolainovik@gmail.com" },
 ]
-license = "Apache-2.0"
+license = { file = "LICENSE" }
 classifiers = [
     'Development Status :: 4 - Beta',
     'Intended Audience :: Developers',
@@ -21,7 +21,6 @@ classifiers = [
     'Programming Language :: Python :: 3.11',
     'Programming Language :: Python :: 3.12',
     'Programming Language :: Python :: 3.13',
-    'Programming Language :: Python :: 3.14',
     'Environment :: Web Environment',
     'Framework :: AsyncIO',
 ]
@@ -29,7 +28,7 @@ classifiers = [
 dynamic = ["version", "readme"]

 dependencies = [
-    "aiohttp >= 3.9.2, < 4.0.0",
+    "aiohttp >= 3.9.1, < 4.0.0",
     "aioitertools >= 0.5.1, < 1.0.0",
     "botocore >= 1.40.46, < 1.40.62", # NOTE: When updating, always keep `project.optional-dependencies` aligned
     "python-dateutil >= 2.1, < 3.0.0",
