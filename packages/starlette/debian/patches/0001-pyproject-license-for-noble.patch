Description: Soften pyproject metadata for Noble's hatchling
 Noble's python3-hatchling rejects two pieces of starlette 1.0.0's
 pyproject during `dh_auto_clean`: the PEP 639
 `license = "BSD-3-Clause"` + `license-files = [...]` pair (older
 hatchling wants the legacy table form), and the
 `Programming Language :: Python :: 3.14` trove classifier (unknown
 to the Noble classifier table). Translate both back to the form
 Noble accepts; neither changes runtime behavior or wheel content
 beyond the metadata.
Author: Avalan Packaging Team <avalan@avalan.ai>
Forwarded: not-needed
Last-Update: 2026-05-19

--- a/pyproject.toml
+++ b/pyproject.toml
@@ -7,8 +7,7 @@
 dynamic = ["version"]
 description = "The little ASGI library that shines."
 readme = "README.md"
-license = "BSD-3-Clause"
-license-files = ["LICENSE.md"]
+license = { file = "LICENSE.md" }
 requires-python = ">=3.10"
 authors = [
     { name = "Tom Christie", email = "tom@tomchristie.com" }
@@ -27,7 +26,6 @@
     "Programming Language :: Python :: 3.11",
     "Programming Language :: Python :: 3.12",
     "Programming Language :: Python :: 3.13",
-    "Programming Language :: Python :: 3.14",
     "Topic :: Internet :: WWW/HTTP",
 ]
 dependencies = [
