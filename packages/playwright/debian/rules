#!/usr/bin/make -f

export PYBUILD_NAME=playwright
export PYBUILD_SYSTEM=pyproject

# Block any accidental network use during build/test. The PLAYWRIGHT_
# variables specifically prevent setup.py from downloading the
# upstream browser-driver bundles (which we deliberately exclude).
export PIP_NO_INDEX=1
export PIP_NO_BUILD_ISOLATION=1
export PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
export PLAYWRIGHT_SKIP_DRIVER_DOWNLOAD=1

# setuptools-scm needs a version when building from the GitHub source
# archive (no PKG-INFO, no .git directory). Pin it.
export SETUPTOOLS_SCM_PRETEND_VERSION_FOR_PLAYWRIGHT=1.55.0

%:
	dh $@ --buildsystem=pybuild

# Upstream's tests need a running browser (chromium/firefox) plus
# pytest-asyncio at floors that float across point releases. Skip at
# build time; correctness comes from upstream CI and Avalan's
# autopkgtest smoke import.
override_dh_auto_test:
	@echo "Skipping upstream tests at build time; see debian/tests/."
