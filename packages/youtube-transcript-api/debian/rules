#!/usr/bin/make -f

export PYBUILD_NAME=youtube_transcript_api
export PYBUILD_SYSTEM=pyproject

# Block any accidental network use during build/test.
export PIP_NO_INDEX=1
export PIP_NO_BUILD_ISOLATION=1

%:
	dh $@ --buildsystem=pybuild

# Upstream's tests live alongside the package and need httpretty
# (<1.1), pytest (^8.3), and coverage (^7.6) -- httpretty is not in
# Noble at a matching floor. Skip at build time; correctness comes
# from upstream CI and Avalan's autopkgtest smoke import.
override_dh_auto_test:
	@echo "Skipping upstream tests at build time; see debian/tests/."
