#!/usr/bin/make -f

export PYBUILD_NAME=aioboto3
export PYBUILD_SYSTEM=pyproject

# Block any accidental network use during build/test.
export PIP_NO_INDEX=1
export PIP_NO_BUILD_ISOLATION=1

# The sdist ships a pre-generated `aioboto3/_version.py` with the
# version baked in, so setuptools-scm's fallback path is exercised
# rather than its git-tag probe. Pin the version explicitly so a
# stray VCS check inside the build container cannot override it.
export SETUPTOOLS_SCM_PRETEND_VERSION=15.5.0

%:
	dh $@ --buildsystem=pybuild

# Upstream's tests stand up a moto server, exercise live S3 mocks,
# and require dev-only pytest plugins not in Noble's archive
# (moto, pytest-cov, ...); skip at build time. The Avalan smoke
# import covers the runtime entry point.
override_dh_auto_test:
	@echo "Skipping upstream tests at build time."
