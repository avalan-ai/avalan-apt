Description: Relax setuptools-scm constraint for Ubuntu Noble
 Noble ships python3-setuptools-scm 8.x, which exceeds the upstream
 upper bound `< 7` and incorporates the standalone
 `setuptools_scm_git_archive` plugin into the main package (the
 git-archive support is integrated from setuptools-scm 7 onward).
 Loosen the upper bound and drop the obsolete plugin dependency so
 the package builds against Noble's archive setuptools-scm. The
 SETUPTOOLS_SCM_PRETEND_VERSION_FOR_AIOMYSQL export in debian/rules
 keeps the version stable across the relaxed constraint.
Author: Avalan Packaging Team <avalan@avalan.ai>
Forwarded: not-needed
Last-Update: 2026-05-18

--- a/pyproject.toml
+++ b/pyproject.toml
@@ -4,8 +4,7 @@
     "setuptools >= 42",
 
     # Plugins
-    "setuptools_scm[toml] >= 6.4, < 7",
-    "setuptools_scm_git_archive >= 1.1",
+    "setuptools_scm[toml] >= 6.4",
 ]
 build-backend = "setuptools.build_meta"
 
