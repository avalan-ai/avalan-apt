Description: Soften pyproject for Noble's setuptools + classifier table
 Three small, independent metadata tweaks bundled into one patch
 because they collapse to the same goal -- making anyio build against
 Noble's archive without an unreleased setuptools:
 .
 * Relax the strict `setuptools >= 77` build-system pin to plain
   `setuptools`. Noble ships python3-setuptools 68; the actual build
   machinery anyio uses (pep517 wheel + setuptools.build_meta) works
   on every release back to setuptools 64. Upstream lifted the floor
   solely so PEP 639 SPDX `license = "MIT"` validation would succeed.
 * Rewrite the PEP 639 SPDX string `license = "MIT"` back to the
   legacy `license = { file = "LICENSE" }` table form Noble's older
   setuptools accepts; otherwise wheel metadata validation rejects
   the pyproject as ambiguous against the auto-detected LICENSE.
 * Drop the `Programming Language :: Python :: 3.14` trove
   classifier. Noble's setuptools classifier table predates Python
   3.14 and refuses to emit the wheel until the unknown entry is
   removed. Purely informational; no runtime impact.
Author: Avalan Packaging Team <avalan@avalan.ai>
Forwarded: not-needed
Last-Update: 2026-05-19

--- a/pyproject.toml
+++ b/pyproject.toml
@@ -1,6 +1,6 @@
 [build-system]
 requires = [
-    "setuptools >= 77",
+    "setuptools",
     "setuptools_scm >= 6.4"
 ]
 build-backend = "setuptools.build_meta"
@@ -10,7 +10,7 @@ name = "anyio"
 description = "High-level concurrency and networking framework on top of asyncio or Trio"
 readme = "README.rst"
 authors = [{name = "Alex Grönholm", email = "alex.gronholm@nextday.fi"}]
-license = "MIT"
+license = { file = "LICENSE" }
 classifiers = [
     "Development Status :: 5 - Production/Stable",
     "Intended Audience :: Developers",
@@ -23,7 +23,6 @@ classifiers = [
     "Programming Language :: Python :: 3.11",
     "Programming Language :: Python :: 3.12",
     "Programming Language :: Python :: 3.13",
-    "Programming Language :: Python :: 3.14",
 ]
 requires-python = ">= 3.9"
 dependencies = [
