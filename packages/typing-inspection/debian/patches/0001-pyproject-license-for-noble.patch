Description: Soften pyproject metadata for Noble's hatchling
 Noble's python3-hatchling rejects two pieces of upstream's
 pyproject during `dh_auto_clean`: the PEP 639 `license = "MIT"` +
 `license-files = [...]` pair (older hatchling wants the legacy
 table form) and the `Programming Language :: Python :: 3.14`
 trove classifier (unknown to Noble's classifier table). Translate
 both back to the form Noble accepts. Equivalent wheel metadata;
 no runtime impact.
Author: Avalan Packaging Team <avalan@avalan.ai>
Forwarded: not-needed
Last-Update: 2026-05-19

--- a/pyproject.toml
+++ b/pyproject.toml
@@ -5,8 +5,7 @@
 [project]
 name = 'typing-inspection'
 version = '0.4.2'
-license = "MIT"
-license-files = ['LICENSE']
+license = { file = "LICENSE" }
 description = 'Runtime typing introspection tools'
 authors = [
     {name = 'Victorien Plot', email = 'contact@vctrn.dev'},
@@ -23,7 +22,6 @@
     'Programming Language :: Python :: 3.11',
     'Programming Language :: Python :: 3.12',
     'Programming Language :: Python :: 3.13',
-    'Programming Language :: Python :: 3.14',
     'Typing :: Typed',
     'Intended Audience :: Developers',
     'Topic :: Software Development :: Libraries :: Python Modules',
